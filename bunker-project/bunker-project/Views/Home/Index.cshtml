    // ==================== UI FUNCTIONS ====================

    function showLobbySection() {
        document.getElementById('lobbySection').style.display = 'block';
        document.getElementById('roomSection').style.display = 'none';
    }

    function showRoomSection() {
        document.getElementById('lobbySection').style.display = 'none';
        document.getElementById('roomSection').style.display = 'block';
        document.getElementById('roomLobby').style.display = 'block';
        document.getElementById('gameSection').style.display = 'none';
        document.getElementById('myPlayerSection').style.display = 'block';
    }

    function updateRoomUI() {
        if (!currentRoom) return;
        
        document.getElementById('currentRoomName').textContent = currentRoom.name;
        document.getElementById('currentRoomId').textContent = `ID: ${currentRoom.id}`;
        document.getElementById('currentRoomState').textContent = currentRoom.state === 'Lobby' ? 'Лобі' : 'Гра';
        
        const playerCount = Object.keys(roomPlayers).length;
        document.getElementById('roomPlayerCount').textContent = `${playerCount}/${currentRoom.maxPlayers}`;
        
        // Показуємо кнопку GM панелі тільки хосту
        const gmPanelBtn = document.getElementById('gmPanelBtn');
        if (isHost) {
            gmPanelBtn.style.display = 'inline-block';
        } else {
            gmPanelBtn.style.display = 'none';
        }
        
        // Показуємо кнопку старту тільки хосту
        const startBtn = document.getElementById('startGameBtn');
        if (isHost && currentRoom.state === 'Lobby') {
            startBtn.style.display = 'inline-block';
            startBtn.disabled = playerCount < 4;
            startBtn.title = playerCount < 4 ? 'Потрібно мінімум 4 гравці' : '';
        } else {
            startBtn.style.display = 'none';
        }
        
        // Показуємо кнопку голосування тільки хосту під час гри
        const votingBtn = document.getElementById('startVotingBtn');
        if (isHost && currentRoom.state === 'Playing' && !currentVoting) {
            votingBtn.style.display = 'inline-block';
        } else {
            votingBtn.style.display = 'none';
        }
        
        // Текст очікування
        const waitingText = document.getElementById('waitingText');
        if (playerCount < 4) {
            waitingText.textContent = `Очікування гравців... (потрібно ще ${4 - playerCount})`;
            waitingText.style.display = 'block';
        } else if (!isHost) {
            waitingText.textContent = 'Очікування старту гри від хоста...';
            waitingText.style.display = 'block';
        } else {
            waitingText.style.display = 'none';
        }
        
        renderRoomPlayers();
        
        if (currentRoom.state !== 'Lobby') {
            updatePlayersTable();
        }
    }

    function renderRoomsList(rooms) {
        const container = document.getElementById('roomsList');
        
        if (!rooms || rooms.length === 0) {
            container.innerHTML = '<p class="no-rooms">Немає доступних кімнат. Створіть свою!</p>';
            return;
        }
        
        container.innerHTML = rooms.map(room => `
            <div class="room-card ${!room.canJoin ? 'room-full' : ''}">
                <div class="room-card-header">
                    <span class="room-card-name">${room.name}</span>
                    ${room.hasPassword ? '<span class="room-lock">🔒</span>' : ''}
                </div>
                <div class="room-card-info">
                    <span class="room-host">Хост: ${room.hostName}</span>
                    <span class="room-players">${room.playerCount}/${room.maxPlayers} гравців</span>
                </div>
                <button class="btn-join" onclick="joinRoom('${room.id}', ${room.hasPassword})" ${!room.canJoin ? 'disabled' : ''}>
                    ${room.canJoin ? 'Приєднатися' : 'Заповнено'}
                </button>
            </div>
        `).join('');
    }

    function renderRoomPlayers() {
        const container = document.getElementById('roomPlayersList');
        const players = Object.values(roomPlayers);
        
        container.innerHTML = players.map((p, i) => `
            <div class="room-player-card ${p.connectionId === myConnectionId ? 'my-player' : ''} ${p.isHost ? 'host-player' : ''}">
                <span class="player-number">#${i + 1}</span>
                <span class="player-name">${p.name}</span>
                ${p.isHost ? '<span class="host-badge">Хост</span>' : ''}
                ${p.connectionId === myConnectionId ? '<span class="you-badge">Ви</span>' : ''}
            </div>
        `).join('');
    }

    function toCamelCase(str) {
        return str.charAt(0).toLowerCase() + str.slice(1);
    }

    function updatePlayersTable() {
        const tbody = document.getElementById('playersTableBody');
        const players = Object.values(roomPlayers);
        
        if (players.length === 0) {
            tbody.innerHTML = `<tr><td colspan="14" style="text-align: center; color: var(--color-text-muted); padding: 2rem;">Немає гравців</td></tr>`;
            return;
        }
        
        tbody.innerHTML = players.map((player, index) => `
            <tr class="${player.connectionId === myConnectionId ? 'my-player-row' : ''}" data-player="${player.connectionId}">
                <td class="player-number">#${index + 1}</td>
                <td class="player-name">${player.name}${player.connectionId === myConnectionId ? ' <span class="my-badge">(Я)</span>' : ''}${player.isHost ? ' <span class="host-badge-small">Хост</span>' : ''}</td>
                <td>${renderTableCell(player, 'personality')}</td>
                <td>${renderTableCell(player, 'body')}</td>
                <td>${renderTableCell(player, 'profession')}</td>
                <td>${renderTableCell(player, 'physicalHealth')}</td>
                <td>${renderTableCell(player, 'mentalHealth')}</td>
                <td>${renderTableCell(player, 'hobby')}</td>
                <td>${renderTableCell(player, 'characterTrait')}</td>
                <td>${renderTableCell(player, 'phobia')}</td>
                <td>${renderTableCell(player, 'traits')}</td>
                <td>${renderTableCell(player, 'inventory')}</td>
                <td>${renderTableCell(player, 'secret')}</td>
                <td>${renderTableCell(player, 'secretGoal')}</td>
            </tr>
        `).join('');
        
        document.getElementById('playerCount').textContent = `${players.length}/${currentRoom?.maxPlayers || 12}`;
    }

    function renderTableCell(player, charKey) {
        const revealed = player.revealed && player.revealed[charKey];
        if (revealed) {
            const value = player.revealedData && player.revealedData[charKey] ? player.revealedData[charKey] : 'Розкрито';
            return `<div class="char-revealed">${value}</div>`;
        }
        return `<span class="char-hidden">Приховано</span>`;
    }

    // Helper для типу таємної цілі
    function getSecretGoalTypeLabel(type) {
        const types = {
            'dark': 'Темна',
            'meme': 'Мемна',
            'normal': 'Нормальна',
            'adult': 'Дорослий контент',
            'mixed': 'Змішана'
        };
        return types[type] || 'Невідомо';
    }

    // Рендер карток моїх характеристик
    function renderMyPlayerCards(player) {
        const container = document.getElementById("myPlayerCards");
        if (!container || !player) return;
        
        const revealed = player.revealed || {};
        
        function createTooltipHtml(text, typeClass) {
            if (!text) return '';
            return `<span class="tooltip-trigger ${typeClass}" title="">!</span><div class="tooltip-content">${text}</div>`;
        }
        
        function charWithTooltip(name, tooltip, typeClass) {
            if (!tooltip) return name;
            return `<span class="characteristic-with-tooltip"><span>${name}</span>${createTooltipHtml(tooltip, typeClass)}</span>`;
        }
        
        container.innerHTML = `
            <!-- Особистість -->
            <div class="char-card ${revealed.personality ? 'card-revealed' : ''}">
                <h3 class="char-card-title">Особистість</h3>
                <div class="char-row"><span class="char-label">Вік:</span><span class="char-value">${player.personality.age} років</span></div>
                <div class="char-row"><span class="char-label">Стать:</span><span class="char-value">${player.personality.sex}${player.personality.isChildfree ? " (чайлдфрі)" : ""}</span></div>
                <div class="char-row"><span class="char-label">Орієнтація:</span><span class="char-value">${player.personality.sexOrientation}</span></div>
                <div class="char-row">${revealed.personality ? '<span class="status-revealed">Відкрито для всіх</span>' : '<button class="char-btn locked" onclick="reveal(\'Personality\')">Розкрити всім</button>'}</div>
            </div>

            <!-- Статура -->
            <div class="char-card ${revealed.body ? 'card-revealed' : ''}">
                <h3 class="char-card-title">Статура</h3>
                <div class="char-row"><span class="char-label">Зріст:</span><span class="char-value">${player.body.height} см</span></div>
                <div class="char-row"><span class="char-label">Вага:</span><span class="char-value">${player.body.weight} кг</span></div>
                <div class="char-row"><span class="char-label">Тип тіла:</span><span class="char-value">${player.body.bodyType}</span></div>
                <div class="char-row">${revealed.body ? '<span class="status-revealed">Відкрито для всіх</span>' : '<button class="char-btn locked" onclick="reveal(\'Body\')">Розкрити всім</button>'}</div>
            </div>

            <!-- Професія -->
            <div class="char-card ${revealed.profession ? 'card-revealed' : ''}">
                <h3 class="char-card-title">Професія</h3>
                <div class="char-row"><span class="char-label">Назва:</span><span class="char-value">${charWithTooltip((player.profession.name || 'Безробітний') + (player.profession.selectedItem ? ' <span class="selected-item-badge">(+' + player.profession.selectedItem + ')</span>' : ''), player.profession.tooltip, 'profession')}</span></div>
                <div class="char-row"><span class="char-label">Досвід:</span><span class="char-value">${player.profession.experienceYears || 0} років</span></div>
                <div class="char-row">${revealed.profession ? '<span class="status-revealed">Відкрито для всіх</span>' : '<button class="char-btn locked" onclick="reveal(\'Profession\')">Розкрити всім</button>'}</div>
            </div>

            <!-- Фізичне здоров'я -->
            <div class="char-card ${revealed.physicalHealth ? 'card-revealed' : ''}">
                <h3 class="char-card-title">Фізичне здоров'я</h3>
                <div class="char-row"><span class="char-label">Стан:</span><span class="char-value">${charWithTooltip(player.physicalHealth.name || 'Здоровий', player.physicalHealth.tooltip, 'physical')}</span></div>
                <div class="char-row">${revealed.physicalHealth ? '<span class="status-revealed">Відкрито для всіх</span>' : '<button class="char-btn locked" onclick="reveal(\'PhysicalHealth\')">Розкрити всім</button>'}</div>
            </div>

            <!-- Психічне здоров'я -->
            <div class="char-card ${revealed.mentalHealth ? 'card-revealed' : ''}">
                <h3 class="char-card-title">Психічне здоров'я</h3>
                <div class="char-row"><span class="char-label">Стан:</span><span class="char-value">${charWithTooltip(player.mentalHealth.name || 'Стабільний', player.mentalHealth.tooltip, 'mental')}</span></div>
                <div class="char-row">${revealed.mentalHealth ? '<span class="status-revealed">Відкрито для всіх</span>' : '<button class="char-btn locked" onclick="reveal(\'MentalHealth\')">Розкрити всім</button>'}</div>
            </div>

            <!-- Хобі -->
            <div class="char-card ${revealed.hobby ? 'card-revealed' : ''}">
                <h3 class="char-card-title">Хобі</h3>
                <div class="char-row"><span class="char-label">Заняття:</span><span class="char-value">${charWithTooltip(player.hobby.name || 'Немає хобі', player.hobby.tooltip, 'hobby')}</span></div>
                <div class="char-row">${revealed.hobby ? '<span class="status-revealed">Відкрито для всіх</span>' : '<button class="char-btn locked" onclick="reveal(\'Hobby\')">Розкрити всім</button>'}</div>
            </div>

            <!-- Риса характеру -->
            <div class="char-card ${revealed.characterTrait ? 'card-revealed' : ''}">
                <h3 class="char-card-title">Риса характеру</h3>
                <div class="char-row"><span class="char-label">Тип:</span><span class="char-value">${player.characterTrait?.name || 'Невизначений'}</span></div>
                <div class="char-row">${revealed.characterTrait ? '<span class="status-revealed">Відкрито для всіх</span>' : '<button class="char-btn locked" onclick="reveal(\'CharacterTrait\')">Розкрити всім</button>'}</div>
            </div>

            <!-- Фобія -->
            <div class="char-card ${revealed.phobia ? 'card-revealed' : ''}">
                <h3 class="char-card-title">Фобія</h3>
                <div class="char-row"><span class="char-label">Страх:</span><span class="char-value">${charWithTooltip(player.phobia?.name || 'Немає фобій', player.phobia?.tooltip, 'phobia')}</span></div>
                <div class="char-row">${revealed.phobia ? '<span class="status-revealed">Відкрито для всіх</span>' : '<button class="char-btn locked" onclick="reveal(\'Phobia\')">Розкрити всім</button>'}</div>
            </div>

            <!-- Особливості -->
            <div class="char-card ${revealed.traits ? 'card-revealed' : ''}">
                <h3 class="char-card-title">Особливості</h3>
                <div class="char-row"><span class="char-label">Риси:</span><span class="char-value">${charWithTooltip(player.traits?.name || 'Немає особливостей', player.traits?.tooltip, 'trait')}</span></div>
                <div class="char-row">${revealed.traits ? '<span class="status-revealed">Відкрито для всіх</span>' : '<button class="char-btn locked" onclick="reveal(\'Traits\')">Розкрити всім</button>'}</div>
            </div>

            <!-- Інвентар -->
            <div class="char-card ${revealed.inventory ? 'card-revealed' : ''}">
                <h3 class="char-card-title">Інвентар</h3>
                <div class="char-row"><span class="char-label">Предмети:</span><span class="char-value">${player.inventory?.items && player.inventory.items.length > 0 ? player.inventory.items.map(i => i.name).join(', ') : 'Порожній'}</span></div>
                <div class="char-row">${revealed.inventory ? '<span class="status-revealed">Відкрито для всіх</span>' : '<button class="char-btn locked" onclick="reveal(\'Inventory\')">Розкрити всім</button>'}</div>
            </div>

            <!-- Секрет -->
            <div class="char-card ${revealed.secret ? 'card-revealed' : ''}">
                <h3 class="char-card-title">Секрет</h3>
                <div class="char-row"><span class="char-label">Таємниця:</span><span class="char-value">${player.secret?.name || 'Без секретів'}</span></div>
                <div class="char-row">${revealed.secret ? '<span class="status-revealed">Відкрито для всіх</span>' : '<button class="char-btn locked" onclick="reveal(\'Secret\')">Розкрити всім</button>'}</div>
            </div>

            <!-- Таємна ціль -->
            <div class="char-card ${revealed.secretGoal ? 'card-revealed' : ''}">
                <h3 class="char-card-title">Таємна ціль</h3>
                <div class="char-row"><span class="char-label">Ціль:</span><span class="char-value">${charWithTooltip(player.secretGoal?.goal || 'Вижити', player.secretGoal?.tooltip, 'secret-goal')}</span></div>
                <div class="char-row"><span class="char-label">Тип:</span><span class="char-value">${getSecretGoalTypeLabel(player.secretGoal?.type)}</span></div>
                <div class="char-row">${revealed.secretGoal ? '<span class="status-revealed">Відкрито для всіх</span>' : '<button class="char-btn locked" onclick="reveal(\'SecretGoal\')">Розкрити всім</button>'}</div>
            </div>
        `;
        
        // Рендеримо карти
        renderMyCards();
    }

    function addEventMessage(message) {
        const eventDiv = document.getElementById("events");
        const eventItem = document.createElement("div");
        eventItem.className = "event-item";
        eventItem.innerHTML = message;
        
        const placeholder = eventDiv.querySelector('p');
        if (placeholder) placeholder.remove();
        
        eventDiv.insertBefore(eventItem, eventDiv.firstChild);
        while (eventDiv.children.length > 50) {
            eventDiv.removeChild(eventDiv.lastChild);
        }
    }
</script>

