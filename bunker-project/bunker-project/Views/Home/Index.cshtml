@{
    ViewData["Title"] = "Бункер Онлайн";
}

<link rel="stylesheet" href="/css/site.css" />
<link rel="stylesheet" href="/css/tooltip.css" />

<div class="game-container">
    <h1 class="page-title">BUNKER ONLINE</h1>

    <!-- Lobby Section (вибір кімнати) -->
    <div id="lobbySection">
        <div class="lobby-container">
            <!-- Створення кімнати -->
            <div class="create-room-panel">
                <h2 class="section-title">Створити кімнату</h2>
                <form class="create-room-form" onsubmit="createRoom(); return false;">
                    <input id="playerNameCreate" type="text" class="input-field" placeholder="Ваше ім'я..." required />
                    <input id="roomName" type="text" class="input-field" placeholder="Назва кімнати..." required />
                    <div class="form-row">
                        <input id="maxPlayers" type="number" class="input-field small" placeholder="Макс. гравців" value="12" min="4" max="16" />
                        <input id="roomPassword" type="password" class="input-field" placeholder="Пароль (необов'язково)" />
                    </div>
                    <button type="submit" class="btn-primary">Створити кімнату</button>
                </form>
            </div>

            <!-- Список кімнат -->
            <div class="rooms-list-panel">
                <h2 class="section-title">Доступні кімнати</h2>
                <div id="roomsList" class="rooms-list">
                    <p class="no-rooms">Завантаження кімнат...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Room Section (в кімнаті / лобі) -->
    <div id="roomSection" style="display: none;">
        <div class="room-header">
            <div class="room-info">
                <h2 class="room-name" id="currentRoomName">Кімната</h2>
                <span class="room-id" id="currentRoomId">ID: ---</span>
                <span class="room-state" id="currentRoomState">Лобі</span>
            </div>
            <div class="room-actions">
                <button id="gmPanelBtn" class="btn-gm" onclick="toggleGMPanel()" style="display: none;">🎮 GM Панель</button>
                <button id="startVotingBtn" class="btn-vote" onclick="startVoting()" style="display: none;">🗳️ Голосування</button>
                <button id="startGameBtn" class="btn-success" onclick="startGame()" style="display: none;">Почати гру</button>
                <button class="btn-danger" onclick="leaveRoom()">Покинути кімнату</button>
            </div>
        </div>

        <!-- Voting Panel -->
        <div id="votingPanel" class="voting-panel" style="display: none;">
            <div class="voting-header">
                <h3>🗳️ Голосування (Раунд <span id="votingRound">1</span>)</h3>
                <div class="voting-progress">
                    <span id="votingProgressText">0/0 проголосували</span>
                </div>
            </div>
            
            <div class="voting-content">
                <!-- Для гравців - вибір кандидата -->
                <div id="votingCandidates" class="voting-candidates"></div>
                
                <!-- Моє голосування -->
                <div id="myVoteStatus" class="my-vote-status" style="display: none;">
                    Ви проголосували за: <span id="myVoteTarget" class="vote-target"></span>
                </div>
            </div>
            
            <!-- Кнопки хоста -->
            <div id="votingHostControls" class="voting-host-controls" style="display: none;">
                <button class="btn-warning" onclick="endVotingEarly()">Завершити голосування</button>
                <button class="btn-secondary" onclick="cancelVoting()">Скасувати</button>
            </div>
        </div>

        <!-- Voting Results Panel (для хоста) -->
        <div id="votingResultsPanel" class="voting-results-panel" style="display: none;">
            <div class="voting-results-header">
                <h3>📊 Результати голосування</h3>
            </div>
            <div id="votingResultsContent" class="voting-results-content"></div>
            <div id="votingDecisionControls" class="voting-decision-controls">
                <p class="decision-prompt">Оберіть дію:</p>
                <button id="eliminateTopBtn" class="btn-danger" onclick="eliminateTopVoted()">❌ Елімінувати лідера</button>
                <button class="btn-success" onclick="resolveNoElimination()">✓ Нікого не елімінувати</button>
            </div>
        </div>

        <!-- Game Master Panel (тільки для хоста) -->
        <div id="gmPanel" class="gm-panel" style="display: none;">
            <div class="gm-panel-header">
                <h3>🎮 Game Master Panel</h3>
                <button class="btn-close" onclick="toggleGMPanel()">×</button>
            </div>
            <div class="gm-panel-content">
                <!-- Вибір гравця -->
                <div class="gm-section">
                    <label class="gm-label">Вибрати гравця:</label>
                    <select id="gmPlayerSelect" class="gm-select" onchange="loadPlayerDataForGM()">
                        <option value="">-- Виберіть гравця --</option>
                    </select>
                </div>

                <!-- Інформація про вибраного гравця -->
                <div id="gmPlayerInfo" class="gm-player-info" style="display: none;">
                    <h4 id="gmPlayerName">Гравець</h4>
                    
                    <!-- Швидкі дії -->
                    <div class="gm-quick-actions">
                        <button class="btn-gm-action btn-eliminate" onclick="eliminateSelectedPlayer()">❌ Елімінувати</button>
                        <button class="btn-gm-action btn-restore" onclick="restoreSelectedPlayer()">✅ Повернути</button>
                    </div>

                    <!-- Характеристики -->
                    <div class="gm-characteristics">
                        <div class="gm-char-item">
                            <span class="gm-char-name">Професія:</span>
                            <span class="gm-char-value" id="gmProfession">-</span>
                            <div class="gm-char-actions">
                                <button onclick="peekCharacteristic('Profession')" title="Підглянути" class="btn-peek">&#128065;</button>
                                <button onclick="editCharacteristic('Profession')" title="Редагувати">✏️</button>
                                <button onclick="regenerateCharacteristic('Profession')" title="Регенерувати">🔄</button>
                                <button onclick="forceReveal('Profession')" title="Розкрити для всіх">📢</button>
                            </div>
                        </div>
                        <div class="gm-char-item">
                            <span class="gm-char-name">Фіз. здоров'я:</span>
                            <span class="gm-char-value" id="gmPhysicalHealth">-</span>
                            <div class="gm-char-actions">
                                <button onclick="peekCharacteristic('PhysicalHealth')" title="Підглянути" class="btn-peek">&#128065;</button>
                                <button onclick="editCharacteristic('PhysicalHealth')" title="Редагувати">✏️</button>
                                <button onclick="regenerateCharacteristic('PhysicalHealth')" title="Регенерувати">🔄</button>
                                <button onclick="forceReveal('PhysicalHealth')" title="Розкрити для всіх">📢</button>
                            </div>
                        </div>
                        <div class="gm-char-item">
                            <span class="gm-char-name">Псих. здоров'я:</span>
                            <span class="gm-char-value" id="gmMentalHealth">-</span>
                            <div class="gm-char-actions">
                                <button onclick="peekCharacteristic('MentalHealth')" title="Підглянути" class="btn-peek">&#128065;</button>
                                <button onclick="editCharacteristic('MentalHealth')" title="Редагувати">✏️</button>
                                <button onclick="regenerateCharacteristic('MentalHealth')" title="Регенерувати">🔄</button>
                                <button onclick="forceReveal('MentalHealth')" title="Розкрити для всіх">📢</button>
                            </div>
                        </div>
                        <div class="gm-char-item">
                            <span class="gm-char-name">Хобі:</span>
                            <span class="gm-char-value" id="gmHobby">-</span>
                            <div class="gm-char-actions">
                                <button onclick="peekCharacteristic('Hobby')" title="Підглянути" class="btn-peek">&#128065;</button>
                                <button onclick="editCharacteristic('Hobby')" title="Редагувати">✏️</button>
                                <button onclick="regenerateCharacteristic('Hobby')" title="Регенерувати">🔄</button>
                                <button onclick="forceReveal('Hobby')" title="Розкрити для всіх">📢</button>
                            </div>
                        </div>
                        <div class="gm-char-item">
                            <span class="gm-char-name">Риса характеру:</span>
                            <span class="gm-char-value" id="gmCharacterTrait">-</span>
                            <div class="gm-char-actions">
                                <button onclick="peekCharacteristic('CharacterTrait')" title="Підглянути" class="btn-peek">&#128065;</button>
                                <button onclick="editCharacteristic('CharacterTrait')" title="Редагувати">✏️</button>
                                <button onclick="regenerateCharacteristic('CharacterTrait')" title="Регенерувати">🔄</button>
                                <button onclick="forceReveal('CharacterTrait')" title="Розкрити для всіх">📢</button>
                            </div>
                        </div>
                        <div class="gm-char-item">
                            <span class="gm-char-name">Фобія:</span>
                            <span class="gm-char-value" id="gmPhobia">-</span>
                            <div class="gm-char-actions">
                                <button onclick="peekCharacteristic('Phobia')" title="Підглянути" class="btn-peek">&#128065;</button>
                                <button onclick="editCharacteristic('Phobia')" title="Редагувати">✏️</button>
                                <button onclick="regenerateCharacteristic('Phobia')" title="Регенерувати">🔄</button>
                                <button onclick="forceReveal('Phobia')" title="Розкрити для всіх">📢</button>
                            </div>
                        </div>
                        <div class="gm-char-item">
                            <span class="gm-char-name">Особливості:</span>
                            <span class="gm-char-value" id="gmTraits">-</span>
                            <div class="gm-char-actions">
                                <button onclick="peekCharacteristic('Traits')" title="Підглянути" class="btn-peek">&#128065;</button>
                                <button onclick="editCharacteristic('Traits')" title="Редагувати">✏️</button>
                                <button onclick="regenerateCharacteristic('Traits')" title="Регенерувати">🔄</button>
                                <button onclick="forceReveal('Traits')" title="Розкрити для всіх">📢</button>
                            </div>
                        </div>
                        <div class="gm-char-item">
                            <span class="gm-char-name">Секрет:</span>
                            <span class="gm-char-value" id="gmSecret">-</span>
                            <div class="gm-char-actions">
                                <button onclick="peekCharacteristic('Secret')" title="Підглянути" class="btn-peek">&#128065;</button>
                                <button onclick="editCharacteristic('Secret')" title="Редагувати">✏️</button>
                                <button onclick="regenerateCharacteristic('Secret')" title="Регенерувати">🔄</button>
                                <button onclick="forceReveal('Secret')" title="Розкрити для всіх">📢</button>
                            </div>
                        </div>
                        <div class="gm-char-item">
                            <span class="gm-char-name">Таємна ціль:</span>
                            <span class="gm-char-value" id="gmSecretGoal">-</span>
                            <div class="gm-char-actions">
                                <button onclick="peekCharacteristic('SecretGoal')" title="Підглянути" class="btn-peek">&#128065;</button>
                                <button onclick="editCharacteristic('SecretGoal')" title="Редагувати">✏️</button>
                                <button onclick="regenerateCharacteristic('SecretGoal')" title="Регенерувати">🔄</button>
                                <button onclick="forceReveal('SecretGoal')" title="Розкрити для всіх">📢</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Гравці в кімнаті (Лобі) -->
        <div id="roomLobby">
            <h3 class="section-title">Гравці в кімнаті: <span id="roomPlayerCount">0/12</span></h3>
            <div id="roomPlayersList" class="room-players-grid"></div>
            <p class="waiting-text" id="waitingText">Очікування гравців для початку гри...</p>
        </div>

        <!-- My Player Detailed Cards Section (тільки для власника) -->
        <div id="myPlayerSection" style="display:none;">
            <h2 class="section-title">Мої характеристики (бачу тільки я)</h2>
            <div id="myPlayerCards" class="player-cards-grid"></div>
            
            <!-- Мої спеціальні карти -->
            <h2 class="section-title" style="margin-top: 2rem;">🃏 Мої спеціальні карти</h2>
            <div id="myCardsSection" class="cards-grid"></div>
        </div>

        <!-- Players Table Section (під час гри) -->
        <div id="gameSection" style="display: none;">
            <!-- Apocalypse & Bunker Info -->
            <div class="game-info-panels">
                <div class="apocalypse-panel" id="apocalypsePanel">
                    <h3 class="panel-title">☢️ Апокаліпсис</h3>
                    <div class="panel-content" id="apocalypseContent">
                        <p>Завантаження...</p>
                    </div>
                </div>
                <div class="bunker-panel" id="bunkerPanel">
                    <h3 class="panel-title">🏠 Бункер</h3>
                    <div class="panel-content" id="bunkerContent">
                        <p>Завантаження...</p>
                    </div>
                </div>
            </div>
            
            <h2 class="section-title">
                Гравці в бункері: <span class="bunker-count" id="playerCount">0/6</span>
            </h2>

            <div style="overflow-x: auto;">
                <table class="players-table" id="playersTable">
                    <thead>
                        <tr>
                            <th style="width: 50px;">№</th>
                            <th style="min-width: 150px;">Ім'я гравця</th>
                            <th style="min-width: 200px;">Особистість</th>
                            <th style="min-width: 200px;">Статура</th>
                            <th style="min-width: 180px;">Професія</th>
                            <th style="min-width: 180px;">Фізичне здоров'я</th>
                            <th style="min-width: 180px;">Психічне здоров'я</th>
                            <th style="min-width: 180px;">Хобі</th>
                            <th style="min-width: 180px;">Риса характеру</th>
                            <th style="min-width: 180px;">Фобія</th>
                            <th style="min-width: 180px;">Особливості</th>
                            <th style="min-width: 180px;">Інвентар</th>
                            <th style="min-width: 180px;">Секрет</th>
                            <th style="min-width: 200px;">Таємна ціль</th>
                        </tr>
                    </thead>
                    <tbody id="playersTableBody">
                        <tr>
                            <td colspan="14" style="text-align: center; color: var(--color-text-muted); padding: 2rem;">
                                Очікування гравців...
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Events Section -->
    <div class="events-section">
        <h2 class="section-title">Події</h2>
        <div id="events">
            <p style="color: var(--color-text-muted); text-align: center;">Тут будуть відображатися події гри...</p>
        </div>
    </div>
</div>

<!-- Join Room Modal -->
<div id="joinModal" class="modal" style="display: none;">
    <div class="modal-content">
        <h3>Приєднатися до кімнати</h3>
        <form onsubmit="submitJoinRoom(); return false;">
            <input id="playerNameJoin" type="text" class="input-field" placeholder="Ваше ім'я..." required />
            <input id="joinRoomPassword" type="password" class="input-field" placeholder="Пароль (якщо є)" />
            <input type="hidden" id="joinRoomId" />
            <div class="modal-actions">
                <button type="button" class="btn-secondary" onclick="closeJoinModal()">Скасувати</button>
                <button type="submit" class="btn-primary">Приєднатися</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Characteristic Modal -->
<div id="editCharModal" class="modal" style="display: none;">
    <div class="modal-content">
        <h3>Редагувати характеристику</h3>
        <p id="editCharInfo" class="edit-char-info"></p>
        <form onsubmit="submitEditCharacteristic(); return false;">
            <input id="editCharValue" type="text" class="input-field" placeholder="Нове значення..." required />
            <input type="hidden" id="editCharName" />
            <div class="modal-actions">
                <button type="button" class="btn-secondary" onclick="closeEditCharModal()">Скасувати</button>
                <button type="button" class="btn-warning" onclick="clearCharacteristic()">Очистити</button>
                <button type="submit" class="btn-primary">Зберегти</button>
            </div>
        </form>
    </div>
</div>

<!-- Use Card Modal -->
<div id="useCardModal" class="modal" style="display: none;">
    <div class="modal-content modal-card">
        <h3 id="useCardTitle">Використати карту</h3>
        <p id="useCardDescription" class="card-modal-desc"></p>
        <form onsubmit="submitUseCard(); return false;">
            <div id="cardTargetSection" style="display: none;">
                <label class="gm-label">Виберіть гравця-ціль:</label>
                <select id="cardTargetPlayer" class="gm-select">
                    <option value="">-- Виберіть гравця --</option>
                </select>
            </div>
            <div id="cardCharacteristicSection" style="display: none; margin-top: 1rem;">
                <label class="gm-label">Виберіть характеристику:</label>
                <select id="cardTargetCharacteristic" class="gm-select">
                    <option value="">-- Виберіть характеристику --</option>
                    <option value="Profession">Професія</option>
                    <option value="PhysicalHealth">Фізичне здоров'я</option>
                    <option value="MentalHealth">Психічне здоров'я</option>
                    <option value="Hobby">Хобі</option>
                    <option value="CharacterTrait">Риса характеру</option>
                    <option value="Phobia">Фобія</option>
                    <option value="Traits">Особливості</option>
                    <option value="Secret">Секрет</option>
                    <option value="SecretGoal">Таємна ціль</option>
                </select>
            </div>
            <input type="hidden" id="useCardId" />
            <div class="modal-actions">
                <button type="button" class="btn-secondary" onclick="closeUseCardModal()">Скасувати</button>
                <button type="submit" class="btn-primary">Використати</button>
            </div>
        </form>
    </div>
</div>

<!-- Card Approval Modal (для хоста) -->
<div id="cardApprovalModal" class="modal" style="display: none;">
    <div class="modal-content modal-card">
        <h3>🃏 Запит на використання карти</h3>
        <div id="cardApprovalContent"></div>
        <input type="hidden" id="approvalCardId" />
        <input type="hidden" id="approvalPlayerId" />
        <div class="modal-actions">
            <button type="button" class="btn-danger" onclick="rejectCardApproval()">Відхилити</button>
            <button type="button" class="btn-success" onclick="approveCardApproval()">Підтвердити</button>
        </div>
    </div>
</div>

<!-- Peek Characteristic Modal (тільки для хоста) -->
<div id="peekModal" class="modal" style="display: none;">
    <div class="modal-content modal-peek">
        <h3>&#128065; Підгляд характеристики</h3>
        <div id="peekModalContent"></div>
        <div class="modal-actions">
            <button type="button" class="btn-primary" onclick="closePeekModal()">Закрити</button>
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/gameHub")
        .withAutomaticReconnect()
        .build();

    // Дані
    let currentRoom = null;
    let myPlayerData = null;
    let myConnectionId = null;
    let isHost = false;
    let roomPlayers = {}; // connectionId -> player info
    let gmPlayersData = {}; // Повні дані гравців для GM
    let selectedPlayerForGM = null;
    let pendingCardApprovals = []; // Запити на підтвердження карт
    let currentCardToUse = null;
    let pendingJoinRoomId = null; // Для закриття модалки після успішного join
    let currentApocalypse = null;
    let currentBunker = null;
    let currentVoting = null;
    let myVote = null;

    // ==================== SIGNALR HANDLERS ====================

    // Список кімнат оновлено
    connection.on("RoomsListUpdated", function (rooms) {
        console.log("Rooms updated:", rooms);
        renderRoomsList(rooms);
    });

    // Кімнату створено
    connection.on("RoomCreated", function (data) {
        console.log("Room created:", data);
        currentRoom = data.room;
        myPlayerData = data.player;
        isHost = data.isHost;
        myConnectionId = data.player.connectionId;
        
        // Зберігаємо сесію в localStorage
        saveSession(currentRoom.id, myPlayerData.name);
        
        roomPlayers = {};
        roomPlayers[myConnectionId] = {
            name: myPlayerData.name,
            connectionId: myConnectionId,
            isHost: isHost,
            revealed: myPlayerData.revealed || {}
        };
        
        showRoomSection();
        updateRoomUI();
        renderMyPlayerCards(myPlayerData);
        addEventMessage(`Ви створили кімнату <span class="event-room">${currentRoom.name}</span>`);
    });

    // Приєднались до кімнати
    connection.on("RoomJoined", function (data) {
        console.log("Joined room:", data);
        currentRoom = data.room;
        myPlayerData = data.player;
        isHost = data.isHost;
        myConnectionId = data.player.connectionId;
        
        // Закриваємо модалку join якщо була відкрита
        pendingJoinRoomId = null;
        closeJoinModal();
        
        // Зберігаємо сесію в localStorage
        saveSession(currentRoom.id, myPlayerData.name);
        
        roomPlayers = {};
        data.players.forEach(p => {
            roomPlayers[p.connectionId] = {
                name: p.name,
                connectionId: p.connectionId,
                isHost: p.isHost,
                revealed: p.revealed || {},
                revealedData: {}
            };
        });
        
        showRoomSection();
        updateRoomUI();
        renderMyPlayerCards(myPlayerData);
        addEventMessage(`Ви приєднались до кімнати <span class="event-room">${currentRoom.name}</span>`);
    });

    // Гравець приєднався до кімнати
    connection.on("PlayerJoinedRoom", function (info) {
        console.log("Player joined room:", info);
        roomPlayers[info.connectionId] = {
            name: info.name,
            connectionId: info.connectionId,
            isHost: info.isHost,
            revealed: info.revealed || {},
            revealedData: {}
        };
        updateRoomUI();
        addEventMessage(`Гравець <span class="event-player">${info.name}</span> приєднався`);
    });

    // Гравець покинув кімнату
    connection.on("PlayerLeftRoom", function (info) {
        console.log("Player left room:", info);
        const leftPlayer = roomPlayers[info.connectionId];
        const leftName = leftPlayer?.name || 'Гравець';
        delete roomPlayers[info.connectionId];
        
        // Якщо змінився хост
        if (info.newHostConnectionId) {
            if (roomPlayers[info.newHostConnectionId]) {
                roomPlayers[info.newHostConnectionId].isHost = true;
            }
            if (info.newHostConnectionId === myConnectionId) {
                isHost = true;
                addEventMessage(`Ви тепер хост кімнати!`);
            } else {
                addEventMessage(`<span class="event-player">${info.newHostName}</span> тепер хост`);
            }
        }
        
        updateRoomUI();
        addEventMessage(`Гравець <span class="event-player">${leftName}</span> покинув кімнату`);
    });

    // Покинув кімнату
    connection.on("RoomLeft", function () {
        console.log("Left room");
        currentRoom = null;
        myPlayerData = null;
        isHost = false;
        roomPlayers = {};
        clearSession();
        showLobbySection();
        addEventMessage(`Ви покинули кімнату`);
    });

    // Гра почалась
    connection.on("GameStarted", function (data) {
        console.log("Game started:", data);
        currentRoom.state = data.roomState;
        currentApocalypse = data.apocalypse;
        currentBunker = data.bunker;
        
        document.getElementById('roomLobby').style.display = 'none';
        document.getElementById('gameSection').style.display = 'block';
        document.getElementById('myPlayerSection').style.display = 'block';
        document.getElementById('currentRoomState').textContent = 'Гра';
        document.getElementById('currentRoomState').classList.add('state-playing');
        document.getElementById('startGameBtn').style.display = 'none';
        
        // Рендеримо апокаліпсис та бункер
        renderApocalypse(data.apocalypse);
        renderBunker(data.bunker);
        
        updatePlayersTable();
        addEventMessage(`Гра почалась! Раунд ${data.currentRound}`);
        
        if (data.apocalypse) {
            addEventMessage(`<span class="event-apocalypse">☢️ Апокаліпсис:</span> ${data.apocalypse.name}`);
        }
        if (data.bunker) {
            addEventMessage(`<span class="event-bunker">🏠 Бункер:</span> ${data.bunker.name}`);
        }
    });

    // Характеристику розкрито
    connection.on("CharacteristicRevealed", function (info) {
        console.log("Characteristic revealed:", info);
        const charKey = toCamelCase(info.characteristicKey);
        
        if (roomPlayers[info.connectionId]) {
            if (!roomPlayers[info.connectionId].revealed) {
                roomPlayers[info.connectionId].revealed = {};
            }
            if (!roomPlayers[info.connectionId].revealedData) {
                roomPlayers[info.connectionId].revealedData = {};
            }
            roomPlayers[info.connectionId].revealed[charKey] = true;
            roomPlayers[info.connectionId].revealedData[charKey] = info.data.value;
        }
        
        // Оновлюємо свої картки якщо це я
        if (info.connectionId === myConnectionId && myPlayerData) {
            if (!myPlayerData.revealed) myPlayerData.revealed = {};
            myPlayerData.revealed[charKey] = true;
            renderMyPlayerCards(myPlayerData);
        }
        
        updatePlayersTable();
        addEventMessage(`<span class="event-player">${info.playerName}</span> розкрив: <span class="revealed-label">${info.data.label}</span>`);
    });

    // Характеристику оновлено (GM змінив)
    connection.on("CharacteristicUpdated", function (info) {
        console.log("Characteristic updated by GM:", info);
        const charKey = toCamelCase(info.characteristicKey);
        
        if (roomPlayers[info.connectionId]) {
            if (!roomPlayers[info.connectionId].revealedData) {
                roomPlayers[info.connectionId].revealedData = {};
            }
            roomPlayers[info.connectionId].revealedData[charKey] = info.data.value;
        }
        
        updatePlayersTable();
        addEventMessage(`<span class="event-gm">GM</span> змінив характеристику <span class="event-player">${info.playerName}</span>`);
    });

    // Мої характеристики відредаговані GM
    connection.on("CharacteristicEdited", function (info) {
        console.log("My characteristic edited:", info);
        myPlayerData = info.player;
        renderMyPlayerCards(myPlayerData);
        addEventMessage(`<span class="event-gm">GM</span> змінив вашу характеристику: ${info.characteristicName}`);
    });

    // Характеристику очищено
    connection.on("CharacteristicCleared", function (info) {
        console.log("My characteristic cleared:", info);
        myPlayerData = info.player;
        renderMyPlayerCards(myPlayerData);
        addEventMessage(`<span class="event-gm">GM</span> очистив вашу характеристику: ${info.characteristicName}`);
    });

    // Характеристику регенеровано
    connection.on("CharacteristicRegenerated", function (info) {
        console.log("My characteristic regenerated:", info);
        myPlayerData = info.player;
        renderMyPlayerCards(myPlayerData);
        addEventMessage(`<span class="event-gm">GM</span> регенерував вашу характеристику: ${info.characteristicName}`);
    });

    // Гравця елімінівано
    connection.on("PlayerEliminated", function (info) {
        console.log("Player eliminated:", info);
        if (roomPlayers[info.connectionId]) {
            roomPlayers[info.connectionId].isEliminated = true;
        }
        updatePlayersTable();
        updateGMPlayerSelect();
        addEventMessage(`<span class="event-eliminate">❌ ${info.playerName}</span> елімінований!`);
    });

    // Гравця повернено
    connection.on("PlayerRestored", function (info) {
        console.log("Player restored:", info);
        if (roomPlayers[info.connectionId]) {
            roomPlayers[info.connectionId].isEliminated = false;
        }
        updatePlayersTable();
        updateGMPlayerSelect();
        addEventMessage(`<span class="event-restore">✅ ${info.playerName}</span> повернено в гру!`);
    });

    // GM отримав дані всіх гравців
    connection.on("AllPlayersData", function (data) {
        console.log("All players data received:", data);
        gmPlayersData = {};
        data.forEach(p => {
            gmPlayersData[p.connectionId] = p;
        });
        updateGMPlayerSelect();
    });

    // GM дія успішна
    connection.on("GMActionSuccess", function (info) {
        console.log("GM action success:", info);
        addEventMessage(`<span class="event-gm">GM</span> ${info.action}: ${info.playerName} - ${info.characteristicName || ''}`);
        // Оновлюємо дані гравців
        if (isHost) {
            connection.invoke("GetAllPlayersData").catch(err => console.error(err));
        }
    });

    // Помилка
    connection.on("ReceiveError", function (message) {
        console.error("Error:", message);
        addEventMessage(`<span class="event-error">Помилка: ${message}</span>`);
        alert(message);
    });

    // ==================== SESSION RESTORE HANDLERS ====================

    // Успішне перепідключення
    connection.on("RejoinSuccess", function (data) {
        console.log("Rejoin success:", data);
        currentRoom = data.room;
        myPlayerData = data.player;
        isHost = data.isHost;
        myConnectionId = data.player.connectionId;
        
        // Оновлюємо сесію
        saveSession(currentRoom.id, myPlayerData.name);
        
        roomPlayers = {};
        data.players.forEach(function(p) {
            roomPlayers[p.connectionId] = {
                name: p.name,
                connectionId: p.connectionId,
                isHost: p.isHost,
                revealed: p.revealed || {},
                revealedData: {},
                isEliminated: p.isEliminated
            };
        });
        
        showRoomSection();
        updateRoomUI();
        renderMyPlayerCards(myPlayerData);
        
        // Якщо гра вже йде — показати ігрову секцію
        if (data.roomState === 'Playing' || data.roomState === 'Voting') {
            currentApocalypse = data.apocalypse;
            currentBunker = data.bunker;
            document.getElementById('roomLobby').style.display = 'none';
            document.getElementById('gameSection').style.display = 'block';
            document.getElementById('myPlayerSection').style.display = 'block';
            document.getElementById('currentRoomState').textContent = data.roomState === 'Playing' ? 'Гра' : 'Голосування';
            document.getElementById('startGameBtn').style.display = 'none';
            if (data.apocalypse) renderApocalypse(data.apocalypse);
            if (data.bunker) renderBunker(data.bunker);
            updatePlayersTable();
        }
        
        addEventMessage(`Сесію відновлено! Ви знову в кімнаті <span class="event-room">${currentRoom.name}</span>`);
    });

    // Перепідключення не вдалося
    connection.on("RejoinFailed", function (message) {
        console.log("Rejoin failed:", message);
        clearSession();
        // Не показуємо alert — просто залишаємо в лобі
    });

    // Інший гравець перепідключився
    connection.on("PlayerReconnected", function (info) {
        console.log("Player reconnected:", info);
        // Оновлюємо connectionId гравця
        var oldKey = null;
        for (var key in roomPlayers) {
            if (roomPlayers[key].name === info.name) {
                oldKey = key;
                break;
            }
        }
        if (oldKey && oldKey !== info.connectionId) {
            var playerData = roomPlayers[oldKey];
            delete roomPlayers[oldKey];
            playerData.connectionId = info.connectionId;
            playerData.isHost = info.isHost;
            roomPlayers[info.connectionId] = playerData;
        }
        updateRoomUI();
        addEventMessage(`Гравець <span class="event-player">${info.name}</span> перепідключився`);
    });

    // ==================== PEEK CHARACTERISTIC HANDLER ====================

    // Хост підглянув приховану характеристику
    connection.on("CharacteristicPeeked", function (info) {
        console.log("Characteristic peeked:", info);
        showPeekModal(info.playerName, info.characteristicKey, info.data, info.isRevealed);
    });

    // ==================== CARD SIGNALR HANDLERS ====================

    // Карта очікує підтвердження
    connection.on("CardPending", function (card) {
        console.log("Card pending:", card);
        renderMyCards();
        addEventMessage(`Карта <span class="card-name">${card.name}</span> очікує підтвердження хоста`);
    });

    // Запит на підтвердження карти (для хоста)
    connection.on("CardApprovalRequest", function (data) {
        console.log("Card approval request:", data);
        pendingCardApprovals.push(data);
        showCardApprovalModal(data);
        addEventMessage(`<span class="event-gm">🃏</span> ${data.playerName} хоче використати карту <span class="card-name">${data.card.name}</span>`);
    });

    // Карта використана
    connection.on("CardUsed", function (data) {
        console.log("Card used:", data);
        if (myPlayerData) {
            const cardIndex = myPlayerData.cards.findIndex(c => c.id === data.card.id);
            if (cardIndex >= 0) {
                myPlayerData.cards[cardIndex] = data.card;
            }
        }
        renderMyCards();
        addEventMessage(`Карта <span class="card-name">${data.card.name}</span> використана: ${data.result}`);
    });

    // Карта відхилена
    connection.on("CardRejected", function (data) {
        console.log("Card rejected:", data);
        if (myPlayerData) {
            const cardIndex = myPlayerData.cards.findIndex(c => c.id === data.card.id);
            if (cardIndex >= 0) {
                myPlayerData.cards[cardIndex] = data.card;
            }
        }
        renderMyCards();
        addEventMessage(`<span class="event-error">Карта ${data.card.name} відхилена: ${data.reason}</span>`);
    });

    // Нова карта отримана
    connection.on("CardReceived", function (card) {
        console.log("Card received:", card);
        if (myPlayerData) {
            if (!myPlayerData.cards) myPlayerData.cards = [];
            myPlayerData.cards.push(card);
        }
        renderMyCards();
        addEventMessage(`<span class="event-card">🃏</span> Ви отримали нову карту: <span class="card-name">${card.name}</span>`);
    });

    // Карта активована (для всіх)
    connection.on("CardActivated", function (data) {
        console.log("Card activated:", data);
        addEventMessage(`<span class="event-card">🃏</span> ${data.playerName} активував карту <span class="card-name">${data.cardName}</span>`);
    });

    // Секрет переглянуто (тільки власнику карти)
    connection.on("SecretViewed", function (data) {
        console.log("Secret viewed:", data);
        alert(`${data.secretType} гравця ${data.targetPlayerName}:\n\n${data.secretValue}`);
        addEventMessage(`Ви дізналися ${data.secretType} гравця ${data.targetPlayerName}`);
    });

    // Характеристику обміняно
    connection.on("CharacteristicSwapped", function (data) {
        console.log("Characteristic swapped:", data);
        myPlayerData = data.player;
        renderMyPlayerCards(myPlayerData);
        addEventMessage(`Вашу характеристику ${data.characteristicName} обміняно з ${data.withPlayerName}`);
    });

    // ==================== VOTING SIGNALR HANDLERS ====================

    // Голосування почалось
    connection.on("VotingStarted", function (data) {
        console.log("Voting started:", data);
        currentVoting = data;
        myVote = null;
        showVotingPanel(data);
        addEventMessage(`<span class="event-voting">🗳️ Голосування почалось!</span> Раунд ${data.round}`);
    });

    // Голос зараховано
    connection.on("VoteCast", function (data) {
        console.log("Vote cast:", data);
        myVote = data;
        document.getElementById('myVoteStatus').style.display = 'block';
        document.getElementById('myVoteTarget').textContent = data.targetName;
        updateVotingCandidates();
        addEventMessage(`Ви проголосували за ${data.targetName}${data.changed ? ' (змінено)' : ''}`);
    });

    // Прогрес голосування
    connection.on("VotingProgress", function (data) {
        console.log("Voting progress:", data);
        document.getElementById('votingProgressText').textContent = `${data.votedCount}/${data.totalVoters} проголосували`;
    });

    // Голосування завершено
    connection.on("VotingEnded", function (data) {
        console.log("Voting ended:", data);
        currentVoting = data;
        
        // Ховаємо панель голосування
        document.getElementById('votingPanel').style.display = 'none';
        
        // Показуємо результати (тільки хосту показуємо кнопки)
        showVotingResults(data);
        
        addEventMessage(`<span class="event-voting">🗳️ Голосування завершено!</span> Лідер: ${data.topVotedPlayerName || 'Нічия'}`);
    });

    // Рішення по голосуванню прийнято
    connection.on("VotingResolved", function (data) {
        console.log("Voting resolved:", data);
        currentVoting = null;
        
        // Ховаємо панель результатів
        document.getElementById('votingResultsPanel').style.display = 'none';
        
        // Оновлюємо UI
        updateRoomUI();
        
        addEventMessage(`<span class="event-voting">⚖️</span> ${data.message}. Раунд ${data.nextRound}`);
    });

    // Голосування скасовано
    connection.on("VotingCancelled", function (data) {
        console.log("Voting cancelled:", data);
        currentVoting = null;
        
        document.getElementById('votingPanel').style.display = 'none';
        document.getElementById('votingResultsPanel').style.display = 'none';
        
        addEventMessage(`<span class="event-warning">⚠️ ${data.message}</span>`);
    });

    // Підключення
    connection.start()
        .then(() => {
            console.log("SignalR connected");
            myConnectionId = connection.connectionId;
            
            // Спроба перепідключення до існуючої сесії
            if (!tryRejoin()) {
                connection.invoke("GetRooms");
            }
            
            // Автозаповнення імені
            prefillPlayerName();
            
            addEventMessage("Підключено до сервера");
        })
        .catch(err => {
            console.error("Connection error:", err);
            addEventMessage("Помилка підключення до сервера");
        });

    // ==================== SESSION & PROFILE FUNCTIONS ====================

    function saveSession(roomId, playerName) {
        try {
            sessionStorage.setItem('bunker_roomId', roomId);
            sessionStorage.setItem('bunker_playerName', playerName);
            // Також зберігаємо ім'я в localStorage для автозаповнення
            localStorage.setItem('bunker_lastPlayerName', playerName);
        } catch (e) { console.warn('Session save failed:', e); }
    }

    function clearSession() {
        try {
            sessionStorage.removeItem('bunker_roomId');
            sessionStorage.removeItem('bunker_playerName');
        } catch (e) {}
    }

    function loadSession() {
        try {
            return {
                roomId: sessionStorage.getItem('bunker_roomId'),
                playerName: sessionStorage.getItem('bunker_playerName')
            };
        } catch (e) { return { roomId: null, playerName: null }; }
    }

    function tryRejoin() {
        var session = loadSession();
        if (session.roomId && session.playerName) {
            console.log('Attempting rejoin:', session);
            connection.invoke("RejoinRoom", session.roomId, session.playerName)
                .catch(function(err) {
                    console.error("RejoinRoom error:", err);
                    clearSession();
                });
            return true;
        }
        return false;
    }

    // Автозаповнення імені з localStorage
    function prefillPlayerName() {
        try {
            var lastPlayerName = localStorage.getItem('bunker_lastPlayerName');
            if (lastPlayerName) {
                var createInput = document.getElementById('playerNameCreate');
                if (createInput && !createInput.value) {
                    createInput.value = lastPlayerName;
                }
            }
        } catch (e) {}
    }

    // ==================== PEEK (EYE ICON) FUNCTIONS ====================

    function peekCharacteristic(charName) {
        var selectedId = document.getElementById('gmPlayerSelect').value;
        if (!selectedId) {
            alert('Спочатку виберіть гравця');
            return;
        }
        connection.invoke("PeekCharacteristic", selectedId, charName)
            .catch(function(err) { console.error("PeekCharacteristic error:", err); });
    }

    function showPeekModal(playerName, charKey, data, isAlreadyRevealed) {
        var statusText = isAlreadyRevealed ? '(вже розкрита для всіх)' : '(прихована від інших)';
        var content = '<div class="peek-info">' +
            '<p><strong>Гравець:</strong> ' + playerName + '</p>' +
            '<p><strong>' + data.label + ':</strong> ' + data.value + '</p>' +
            (data.tooltip ? '<p class="peek-tooltip"><em>' + data.tooltip + '</em></p>' : '') +
            '<p class="peek-status">' + statusText + '</p>' +
            '</div>';
        
        document.getElementById('peekModalContent').innerHTML = content;
        document.getElementById('peekModal').style.display = 'flex';
    }

    function closePeekModal() {
        document.getElementById('peekModal').style.display = 'none';
    }

    // ==================== MOBILE TOOLTIPS ====================
    
    // Відкрити/закрити тултіп по кліку (для мобільних)
    document.addEventListener('click', function(e) {
        const trigger = e.target.closest('.tooltip-trigger');
        if (trigger) {
            e.preventDefault();
            e.stopPropagation();
            // Закриваємо всі інші відкриті тултіпи
            document.querySelectorAll('.tooltip-trigger.active').forEach(t => {
                if (t !== trigger) t.classList.remove('active');
            });
            trigger.classList.toggle('active');
            return;
        }
        // Клік поза тултіпом — закрити всі
        document.querySelectorAll('.tooltip-trigger.active').forEach(t => t.classList.remove('active'));
    });

    // ==================== ROOM FUNCTIONS ====================

    function createRoom() {
        const playerName = document.getElementById('playerNameCreate').value.trim();
        const roomName = document.getElementById('roomName').value.trim();
        const maxPlayers = parseInt(document.getElementById('maxPlayers').value) || 12;
        const password = document.getElementById('roomPassword').value || null;
        
        if (!playerName || !roomName) {
            alert("Введіть ім'я та назву кімнати");
            return;
        }
        
        connection.invoke("CreateRoom", roomName, playerName, maxPlayers, password)
            .catch(err => console.error("CreateRoom error:", err));
    }

    function joinRoom(roomId, hasPassword) {
        if (hasPassword) {
            document.getElementById('joinRoomId').value = roomId;
            document.getElementById('joinModal').style.display = 'flex';
        } else {
            const playerName = prompt("Введіть ваше ім'я:");
            if (playerName && playerName.trim()) {
                connection.invoke("JoinRoom", roomId, playerName.trim(), null)
                    .catch(err => console.error("JoinRoom error:", err));
            }
        }
    }

    function submitJoinRoom() {
        const playerName = document.getElementById('playerNameJoin').value.trim();
        const password = document.getElementById('joinRoomPassword').value || null;
        const roomId = document.getElementById('joinRoomId').value;
        
        if (!playerName) {
            alert("Введіть ваше ім'я");
            return;
        }
        
        // Зберігаємо roomId для перевірки в RoomJoined handler
        pendingJoinRoomId = roomId;
        
        connection.invoke("JoinRoom", roomId, playerName, password)
            .catch(err => {
                console.error("JoinRoom error:", err);
                pendingJoinRoomId = null;
            });
        // Модалка закриється автоматично в RoomJoined handler
    }

    function closeJoinModal() {
        document.getElementById('joinModal').style.display = 'none';
        document.getElementById('playerNameJoin').value = '';
        document.getElementById('joinRoomPassword').value = '';
    }

    function leaveRoom() {
        if (confirm("Ви впевнені, що хочете покинути кімнату?")) {
            connection.invoke("LeaveRoom")
                .catch(err => console.error("LeaveRoom error:", err));
        }
    }

    function startGame() {
        if (confirm("Почати гру?")) {
            connection.invoke("StartGame")
                .catch(err => console.error("StartGame error:", err));
        }
    }

    function reveal(characteristicName) {
        connection.invoke("RevealCharacteristic", characteristicName)
            .catch(err => console.error("RevealCharacteristic error:", err));
    }

    // ==================== APOCALYPSE & BUNKER FUNCTIONS ====================

    function renderApocalypse(apocalypse) {
        const container = document.getElementById('apocalypseContent');
        if (!container) return;
        
        if (!apocalypse) {
            container.innerHTML = '<p>Невідомо</p>';
            return;
        }
        
        const severityColors = {
            'low': '#27ae60',
            'medium': '#f39c12',
            'high': '#e74c3c',
            'extreme': '#8e44ad'
        };
        
        const severityLabels = {
            'low': 'Низька',
            'medium': 'Середня',
            'high': 'Висока',
            'extreme': 'Екстремальна'
        };
        
        container.innerHTML = `
            <h4 class="apocalypse-name">${apocalypse.name}</h4>
            <p class="apocalypse-desc">${apocalypse.description}</p>
            <div class="apocalypse-stats">
                <div class="stat-item">
                    <span class="stat-label">Загроза:</span>
                    <span class="stat-value" style="color: ${severityColors[apocalypse.severity]}">${severityLabels[apocalypse.severity]}</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">Шанс виживання:</span>
                    <span class="stat-value">${apocalypse.survivalChance}%</span>
                </div>
                <div class="stat-item">
                    <span class="stat-label">Тривалість:</span>
                    <span class="stat-value">${apocalypse.duration}</span>
                </div>
            </div>
            <div class="apocalypse-lists">
                <div class="list-section">
                    <span class="list-title">⚠️ Загрози:</span>
                    <ul>${apocalypse.threats.map(t => `<li>${t}</li>`).join('')}</ul>
                </div>
                <div class="list-section">
                    <span class="list-title">✓ Потрібно:</span>
                    <ul>${apocalypse.requirements.map(r => `<li>${r}</li>`).join('')}</ul>
                </div>
            </div>
        `;
    }

    // ==================== VOTING FUNCTIONS ====================

    function startVoting() {
        if (confirm('Почати голосування?')) {
            connection.invoke("StartVoting")
                .catch(err => console.error("StartVoting error:", err));
        }
    }

    function showVotingPanel(data) {
        document.getElementById('votingRound').textContent = data.round;
        document.getElementById('votingProgressText').textContent = `0/${data.eligibleVoters} проголосували`;
        document.getElementById('myVoteStatus').style.display = 'none';
        
        // Показуємо кнопки хоста
        document.getElementById('votingHostControls').style.display = isHost ? 'flex' : 'none';
        
        // Рендеримо кандидатів
        const candidatesContainer = document.getElementById('votingCandidates');
        candidatesContainer.innerHTML = data.candidates.map(c => `
            <div class="voting-candidate ${c.connectionId === myConnectionId ? 'self-candidate' : ''}" 
                 data-connection-id="${c.connectionId}">
                <span class="candidate-name">${c.name}</span>
                ${c.connectionId !== myConnectionId 
                    ? `<button class="btn-vote-for" onclick="voteFor('${c.connectionId}')">Голосувати</button>`
                    : '<span class="self-label">(Ви)</span>'}
            </div>
        `).join('');
        
        document.getElementById('votingPanel').style.display = 'block';
        
        // Ховаємо кнопку голосування
        document.getElementById('startVotingBtn').style.display = 'none';
    }

    function updateVotingCandidates() {
        if (!myVote) return;
        
        // Позначаємо вибраного кандидата
        document.querySelectorAll('.voting-candidate').forEach(el => {
            const connId = el.dataset.connectionId;
            if (connId === myVote.targetConnectionId) {
                el.classList.add('voted-for');
                const btn = el.querySelector('.btn-vote-for');
                if (btn) btn.textContent = '✓ Ваш голос';
            } else {
                el.classList.remove('voted-for');
                const btn = el.querySelector('.btn-vote-for');
                if (btn) btn.textContent = 'Голосувати';
            }
        });
    }

    function voteFor(targetConnectionId) {
        connection.invoke("Vote", targetConnectionId)
            .catch(err => console.error("Vote error:", err));
    }

    function endVotingEarly() {
        if (confirm('Завершити голосування достроково?')) {
            connection.invoke("EndVoting")
                .catch(err => console.error("EndVoting error:", err));
        }
    }

    function cancelVoting() {
        if (confirm('Скасувати голосування?')) {
            connection.invoke("CancelVoting")
                .catch(err => console.error("CancelVoting error:", err));
        }
    }

    function showVotingResults(data) {
        const resultsContainer = document.getElementById('votingResultsContent');
        
        let resultsHtml = '<div class="voting-results-list">';
        data.results.forEach((r, i) => {
            const isTop = i === 0;
            resultsHtml += `
                <div class="vote-result ${isTop ? 'top-voted' : ''}" data-connection-id="${r.connectionId}">
                    <span class="result-rank">#${i + 1}</span>
                    <span class="result-name">${r.playerName}</span>
                    <span class="result-votes">${r.voteCount} голосів</span>
                </div>
            `;
        });
        resultsHtml += '</div>';
        
        if (data.isTie) {
            resultsHtml += '<p class="tie-warning">⚠️ Нічия! Ведучий вирішує.</p>';
        }
        
        // Показуємо хто за кого голосував
        if (data.votes && data.votes.length > 0) {
            resultsHtml += '<div class="votes-breakdown"><h4>Деталі голосування:</h4><ul>';
            data.votes.forEach(v => {
                resultsHtml += `<li><span class="voter">${v.voterName}</span> → <span class="target">${v.targetName}</span></li>`;
            });
            resultsHtml += '</ul></div>';
        }
        
        resultsContainer.innerHTML = resultsHtml;
        
        // Показуємо/ховаємо кнопки рішення (тільки для хоста)
        document.getElementById('votingDecisionControls').style.display = isHost ? 'block' : 'none';
        
        // Оновлюємо кнопку елімінації
        const eliminateBtn = document.getElementById('eliminateTopBtn');
        if (data.topVotedPlayerName) {
            eliminateBtn.textContent = `❌ Елімінувати ${data.topVotedPlayerName}`;
            eliminateBtn.dataset.targetId = data.topVotedPlayerId;
        }
        
        document.getElementById('votingResultsPanel').style.display = 'block';
    }

    function eliminateTopVoted() {
        const btn = document.getElementById('eliminateTopBtn');
        const targetId = btn.dataset.targetId;
        
        if (!targetId) {
            alert('Немає кандидата для елімінації');
            return;
        }
        
        if (confirm('Елімінувати цього гравця?')) {
            connection.invoke("ResolveVoting", targetId)
                .catch(err => console.error("ResolveVoting error:", err));
        }
    }

    function resolveNoElimination() {
        if (confirm('Нікого не елімінувати?')) {
            connection.invoke("ResolveVoting", null)
                .catch(err => console.error("ResolveVoting error:", err));
        }
    }

