    }
}

/* ==================== SPECIAL CARDS STYLES ==================== */
.cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
}

.special-card {
    background: var(--color-bg-secondary);
    border-radius: 12px;
    padding: 1rem;
    border: 2px solid var(--color-border);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

.special-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
}

.special-card.rarity-common::before { background: #95a5a6; }
.special-card.rarity-rare::before { background: #3498db; }
.special-card.rarity-epic::before { background: #9b59b6; }
.special-card.rarity-legendary::before { background: linear-gradient(90deg, #f39c12, #e74c3c, #9b59b6); }

.special-card.rarity-common { border-color: #95a5a6; }
.special-card.rarity-rare { border-color: #3498db; }
.special-card.rarity-epic { border-color: #9b59b6; }
.special-card.rarity-legendary { border-color: #f39c12; box-shadow: 0 0 15px rgba(243, 156, 18, 0.3); }

.special-card.state-pending { opacity: 0.7; }
.special-card.state-used, .special-card.state-rejected { opacity: 0.5; filter: grayscale(50%); }

.special-card:hover:not(.state-used):not(.state-rejected) {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
}

.card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
}

.card-header .card-name {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-text-primary);
}

.card-rarity {
    font-size: 0.75rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-weight: 600;
}

.rarity-common .card-rarity { background: #95a5a6; color: white; }
.rarity-rare .card-rarity { background: #3498db; color: white; }
.rarity-epic .card-rarity { background: #9b59b6; color: white; }
.rarity-legendary .card-rarity { background: linear-gradient(90deg, #f39c12, #e74c3c); color: white; }

.card-description {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.4;
    margin-bottom: 1rem;
}

.card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.card-state {
    font-size: 0.85rem;
    color: var(--color-text-muted);
}

.state-available .card-state { color: #27ae60; }
.state-pending .card-state { color: #f39c12; }
.state-used .card-state { color: #95a5a6; }
.state-rejected .card-state { color: #e74c3c; }

.btn-use-card {
    padding: 0.5rem 1rem;
    background: linear-gradient(135deg, #27ae60, #219a52);
    color: white;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-use-card:hover {
    filter: brightness(1.1);
    transform: scale(1.05);
}

.modal-card {
    max-width: 450px;
}

.card-modal-desc {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
}

.approval-info {
    background: var(--color-bg-primary);
    padding: 1rem;
    border-radius: 8px;
    margin-bottom: 1rem;
}

.approval-info p {
    margin: 0.5rem 0;
}

.event-card {
    font-size: 1.1rem;
}

.card-name {
    color: var(--color-gold);
    font-weight: 600;
}

/* ==================== SCENARIO SECTION HEADER ==================== */
.scenario-section-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    padding: 0 1rem;
}

.section-header-line {
