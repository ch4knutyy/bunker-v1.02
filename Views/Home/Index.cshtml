}

/* Events System */
.gm-event-form {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
}

.gm-select {
    padding: 0.4rem 0.5rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
