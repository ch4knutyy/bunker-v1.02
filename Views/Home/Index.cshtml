}

.event-apocalypse {
    color: #e74c3c;
    font-weight: 600;
}

.event-bunker {
    color: #3498db;
    font-weight: 600;
}

@@media (max-width: 900px) {
    .game-info-panels {
        grid-template-columns: 1fr;
    }
    
    .scenario-section-header {
        gap: 1rem;
    }
    
    .section-header-title {
        font-size: 1.1rem;
        padding: 0.4rem 1rem;
        letter-spacing: 1px;
    }
    
    .section-header-line {
        max-width: 100px;
    }
}

/* ==================== VOTING STYLES ==================== */
.btn-vote {
    padding: 0.75rem 1.5rem;
    background: linear-gradient(135deg, #3498db, #2980b9);
    color: white;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-vote:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
}

.voting-panel {
    background: var(--color-bg-secondary);
    border: 2px solid #3498db;
    border-radius: 12px;
    margin-bottom: 1.5rem;
    overflow: hidden;
}

.voting-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    background: linear-gradient(135deg, #3498db, #2980b9);
    color: white;
}

.voting-header h3 {
    margin: 0;
}

.voting-progress {
    font-size: 0.9rem;
    opacity: 0.9;
}

.voting-content {
    padding: 1.5rem;
}

.voting-candidates {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
}

.voting-candidate {
