    padding: 0.6rem;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s;
}

.btn-eliminate {
    background: #e74c3c;
    color: white;
}

.btn-eliminate:hover {
    background: #c0392b;
}

.btn-restore {
    background: #27ae60;
    color: white;
}

.btn-restore:hover {
    background: #219a52;
}

.gm-characteristics {
    display: flex;
