}

.btn-gm-action {
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
    color: var(--color-text);
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.85rem;
    transition: all 0.2s;
}

.btn-gm-action:hover {
    background: var(--color-gold);
    color: var(--color-bg-primary);
    border-color: var(--color-gold);
}

.btn-send-event {
    background: var(--color-gold);
