}

.section-header-title {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-gold);
    text-transform: uppercase;
    letter-spacing: 2px;
    margin: 0;
    padding: 0.5rem 1.5rem;
    background: var(--color-bg-secondary);
    border: 2px solid var(--color-gold);
    border-radius: 8px;
    text-shadow: 0 0 10px rgba(255, 215, 0, 0.3);
